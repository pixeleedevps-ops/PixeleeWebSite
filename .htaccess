RewriteEngine On

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+acerca-de-pixelee\.html[\s?] [NC]
RewriteRule ^acerca-de-pixelee\.html$ /nosotros/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+beneficios\.html[\s?] [NC]
RewriteRule ^beneficios\.html$ /beneficios/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+desarrollo-web\.html[\s?] [NC]
RewriteRule ^desarrollo-web\.html$ /desarrollo-web/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+desarrollo-a-la-medida\.html[\s?] [NC]
RewriteRule ^desarrollo-a-la-medida\.html$ /desarrollo-a-la-medida/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+marketing-digital\.html[\s?] [NC]
RewriteRule ^marketing-digital\.html$ /marketing-digital/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+diseno-de-marca\.html[\s?] [NC]
RewriteRule ^diseno-de-marca\.html$ /diseno-de-marca/ [R=301,L]
